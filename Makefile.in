GUILE = @GUILE@
GUILD = @GUILD@

GUILE_LOAD_PATH = @GUILE_LOAD_PATH@
GUILE_LOAD_COMPILED_PATH = @GUILE_LOAD_COMPILED_PATH@

GUILE_TARGET = @GUILE_TARGET@

SITE_SCM_DIR = @GUILE_GLOBAL_SITE@
SITE_SCM_GO_DIR = @GUILE_SITE_CCACHE@

BINARIES = arch-info.go cdata.go
SOURCES = arch-info.scm cdata.scm

# execute tests in the test-suite subdir
TESTENV = GUILE_LOAD_PATH= GUILE_AUTO_COMPILE=0 $(GUILE) -L.. -C.. 2>/dev/null
TESTS = arch-info-01.test cdata-01.test cdata-02.test

%.go: %.scm
        GUILE_LOAD_PATH=.:$(GUILE_LOAD_PATH) \
        GUILE_LOAD_COMPILED_PATH=.:$(GUILE_LOAD_COMPILED_PATH) \
          $(GUILD) compile $(GUILE_TARGET) -o $@ $<

.PHONY: default
default: $(BINARIES)
	@true

.PHONY: check
check:
        @(RES="ALL PASS"; export RES; cd test-suite; \
          for test in $(TESTS); do \
            $(TESTENV) $${test}); \
            if test $$? -ne 0; then RES="SOMETHING FAILED"; fi; \
          done; echo $$RES)

.PHONY: install
install: install-srcs install-bins
	@true

.PHONY: uninstall
uninstall:
	@echo "not smart enough to uninstall"

.PHONY: install-srcs
install-srcs:
        @mkdir -p $(DESTDIR)$(SITE_SCM_DIR)/foreign
        @echo "installing sources in $(DESTDIR)$(SITE_SCM_DIR)/foreign"
        @for file in $(SOURCES); do \
	  cp $${file} $(DESTDIR)$(SITE_SCM_DIR)/foreign/$${file}; \
        done
        #@cp $(TOPDIR)/README $(DESTDIR)$(SITE_SCM_DIR)/foreign/README.cdata

.PHONY: install-bins
install-bins: $(BINARIES)
        @mkdir -p $(DESTDIR)$(SITE_GO_DIR)/foreign
        @echo "installing binaries in $(DESTDIR)$(SITE_GO_DIR)/foreign"
        @for file in $(BINARIES); do \
          cp $${file} $(DESTDIR)$(SITE_GO_DIR)/foreign/$${file}; \
        done

.PHONY: install-bins
install-bins: $(BINARIES)

#.PHONY: install-doc
#install-docs: $(BINARIES)

.PHONY: clean
clean:
	rm -f *.go test-suite/*.

.PHONY: dist-clean
distclean:
	rm -f Makefile config.log config.status


.PHONY: dist-hook
dist-hook:

# --- last line ---
